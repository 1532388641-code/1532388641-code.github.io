"src/replenishment.py":`"""安全库存与补货建议。"""

from dataclasses import dataclass
from math import ceil
from typing import Iterable, List


@dataclass(frozen=True)
class ReplenishmentAdvice:
    store_id: str
    sku_id: str
    forecast_14d: float
    safety_stock: int
    current_stock: int
    recommended_qty: int
    risk_level: str


def calculate_safety_stock(
    daily_forecast: Iterable[float],
    lead_time_days: int,
    demand_std: float,
    service_factor: float = 1.65,
) -> int:
    forecast = list(daily_forecast)

    if not forecast:
        return 0

    lead_time_demand = sum(forecast[:lead_time_days])
    buffer = service_factor * demand_std * (lead_time_days ** 0.5)

    return max(0, ceil(lead_time_demand + buffer))


def recommend_quantity(
    forecast_14d: float,
    safety_stock: int,
    current_stock: int,
    inbound_stock: int,
) -> int:
    target_stock = ceil(forecast_14d + safety_stock)
    available = current_stock + inbound_stock

    return max(0, target_stock - available)


def classify_risk(
    current_stock: int,
    forecast_7d: float,
) -> str:
    coverage = current_stock / max(forecast_7d, 1)

    if coverage < 0.5:
        return "HIGH"
    if coverage < 1.0:
        return "MEDIUM"
    return "LOW"
`,
"src/features.py":`from typing import List

FEATURE_COLUMNS = [
    "sales_lag_1",
    "sales_lag_7",
    "sales_lag_14",
    "rolling_mean_7",
    "rolling_std_14",
    "promotion_discount",
    "holiday_distance",
    "temperature",
    "rainfall",
    "store_type",
    "city_level",
    "inventory_turnover",
]


def build_store_features(frame):
    result = frame.copy()

    result["sales_lag_1"] = result.groupby(
        ["store_id", "sku_id"]
    )["net_sales"].shift(1)

    result["sales_lag_7"] = result.groupby(
        ["store_id", "sku_id"]
    )["net_sales"].shift(7)

    result["rolling_mean_7"] = (
        result.groupby(["store_id", "sku_id"])["net_sales"]
        .rolling(7)
        .mean()
        .reset_index(level=[0, 1], drop=True)
    )

    return result.dropna(subset=FEATURE_COLUMNS)
`,
"src/forecast.py":`"""门店级销量预测模型。"""

from lightgbm import LGBMRegressor
from sklearn.metrics import mean_absolute_error


def train_store_model(features, horizon, validation_days):
    train = features.iloc[:-validation_days]
    valid = features.iloc[-validation_days:]

    model = LGBMRegressor(
        n_estimators=480,
        learning_rate=0.035,
        num_leaves=48,
        subsample=0.86,
        colsample_bytree=0.82,
        random_state=42,
    )

    x_train = train.drop(columns=["net_sales", "date"])
    y_train = train["net_sales"]

    model.fit(x_train, y_train)

    prediction = model.predict(
        valid.drop(columns=["net_sales", "date"])
    )

    metrics = {
        "mae": mean_absolute_error(
            valid["net_sales"],
            prediction,
        )
    }

    return model, metrics
`,
