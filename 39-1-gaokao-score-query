<!doctype html>
<html lang="zh-CN">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<meta name="theme-color" content="#f3f6fb">
<title>普通高校招生考试成绩查询</title>
<style>
:root{
  --navy:#183b6b;--navy2:#23558e;--blue:#2f72c4;--gold:#c79535;
  --bg:#f3f6fb;--card:#ffffff;--line:#dfe6ef;--ink:#1f2935;--muted:#708092;
  --green:#24825a;--red:#c84f59;
}
*{box-sizing:border-box}
html,body{margin:0;min-height:100%;background:var(--bg);color:var(--ink);
font-family:"Segoe UI","PingFang SC","Microsoft YaHei",Arial,sans-serif}
button,input{font:inherit;color:inherit}
button{cursor:pointer}
.site{min-height:100vh;display:flex;flex-direction:column}
.topline{height:7px;background:linear-gradient(90deg,var(--navy),var(--blue),var(--gold))}
.header{height:78px;background:#fff;border-bottom:1px solid var(--line);display:flex;align-items:center;padding:0 max(24px,calc((100vw - 1100px)/2))}
.emblem{width:46px;height:46px;border-radius:50%;display:grid;place-items:center;background:var(--navy);color:white;font-family:"STKaiti","KaiTi",serif;font-size:20px;font-weight:800;box-shadow:inset 0 0 0 4px rgba(255,255,255,.17)}
.brand{margin-left:13px}.brand b{display:block;font-size:19px;letter-spacing:1px}.brand span{display:block;margin-top:5px;font-size:10px;color:var(--muted);letter-spacing:1px}
.header-right{margin-left:auto;font-size:10px;color:#7a8795}.header-right strong{color:var(--navy);font-size:11px}
.hero{background:linear-gradient(120deg,#173a68 0%,#255f9e 67%,#2d76bd 100%);color:white;padding:35px max(24px,calc((100vw - 1100px)/2));position:relative;overflow:hidden}
.hero:after{content:"";position:absolute;width:420px;height:420px;border:1px solid rgba(255,255,255,.12);border-radius:50%;right:-80px;top:-230px;box-shadow:0 0 0 55px rgba(255,255,255,.035),0 0 0 110px rgba(255,255,255,.02)}
.hero h1{margin:0;font-size:31px;letter-spacing:2px}.hero p{margin:10px 0 0;color:#d9e7f7;font-size:12px}
.main{width:min(1100px,calc(100% - 32px));margin:24px auto 40px;flex:1}
.notice{background:#fff8e8;border:1px solid #efd7a4;border-left:5px solid var(--gold);padding:12px 15px;font-size:11px;color:#725a2d;line-height:1.7;margin-bottom:16px}
.layout{display:grid;grid-template-columns:minmax(0,1fr) 320px;gap:18px}
.card{background:#fff;border:1px solid var(--line);box-shadow:0 6px 20px rgba(38,69,105,.055)}
.card-head{height:55px;display:flex;align-items:center;padding:0 19px;border-bottom:1px solid var(--line);font-size:15px;font-weight:800;color:var(--navy)}
.card-head span{margin-left:auto;font-size:9px;color:#8b98a6;font-weight:400;letter-spacing:1px}
.query-body{padding:24px}
.form-grid{display:grid;grid-template-columns:1fr 1fr;gap:17px 20px}
.field label{display:block;font-size:11px;font-weight:700;margin-bottom:8px;color:#465666}.field input{width:100%;height:43px;border:1px solid #cfd9e5;background:#fbfcfe;padding:0 12px;outline:none;font-size:13px}.field input:focus{border-color:#5d93cf;box-shadow:0 0 0 3px rgba(47,114,196,.09);background:#fff}
.field.full{grid-column:1/-1}.verify{display:flex;gap:9px}.verify input{flex:1}.captcha{width:112px;height:43px;background:repeating-linear-gradient(-20deg,#edf3f9 0 8px,#f9fbfd 8px 16px);border:1px solid #ccd8e5;display:grid;place-items:center;font:italic 700 18px Georgia,serif;color:var(--navy);letter-spacing:4px;user-select:none}.reload{width:43px;height:43px;border:1px solid #ccd8e5;background:#fff;color:var(--blue)}
.actions{display:flex;gap:10px;margin-top:22px}.primary{height:44px;padding:0 34px;border:0;background:var(--navy);color:#fff;font-weight:800}.secondary{height:44px;padding:0 25px;border:1px solid #bdcad8;background:#fff;color:#536477}.primary:hover{background:#214f86}
.tip-card{padding:18px}.tip-card h3{font-size:13px;color:var(--navy);margin:0 0 12px}.tip-card ol{margin:0;padding-left:19px;font-size:10px;color:#697888;line-height:2}.service{margin-top:14px;padding-top:13px;border-top:1px solid var(--line);font-size:10px;color:#738191;line-height:1.8}
.result{display:none}.result.show{display:block}.query.hide{display:none}
.result-banner{background:linear-gradient(100deg,#173a68,#2d74b7);color:white;padding:19px 22px;display:flex;align-items:center}.result-banner b{font-size:21px}.result-banner span{display:block;margin-top:4px;font-size:10px;color:#dce9f6}.verified{margin-left:auto;border:1px solid rgba(255,255,255,.45);padding:7px 11px;font-size:10px}
.person{display:grid;grid-template-columns:repeat(4,1fr);gap:0;border-bottom:1px solid var(--line)}.person div{padding:15px 17px;border-right:1px solid var(--line)}.person div:last-child{border:0}.person span{display:block;font-size:9px;color:#7f8d9b}.person b{display:block;margin-top:6px;font-size:13px}
.total-area{display:grid;grid-template-columns:260px minmax(0,1fr);gap:0}
.total{padding:27px;text-align:center;border-right:1px solid var(--line);background:#fbfcfe}.total span{display:block;font-size:11px;color:#718091}.total strong{display:block;font-family:"Segoe UI","Microsoft YaHei",Arial,sans-serif;font-size:64px;line-height:1;font-weight:700;color:var(--navy);margin:8px 0;letter-spacing:0}.total em{font-style:normal;color:#677688;font-size:12px;font-weight:600}
.subjects{padding:21px}.subject{display:grid;grid-template-columns:80px 1fr 52px;align-items:center;gap:10px;margin:11px 0}.subject b{font-size:12px}.bar{height:11px;background:#eaf0f6;overflow:hidden}.bar i{display:block;height:100%;background:linear-gradient(90deg,#2c6ebc,#66a5df)}.subject strong{text-align:right;font-family:"Segoe UI","Microsoft YaHei",Arial,sans-serif;font-size:18px;font-weight:700;color:var(--navy);letter-spacing:0}
.result-note{padding:14px 19px;background:#f7fafc;border-top:1px solid var(--line);font-size:10px;color:#6c7986;line-height:1.7}
.result-actions{display:flex;gap:10px;padding:17px 19px;border-top:1px solid var(--line)}.result-actions button{height:39px;padding:0 19px}
.footer{background:#17324f;color:#b9c7d5;padding:20px;text-align:center;font-size:9px;line-height:1.9}
.toast{position:fixed;left:50%;bottom:30px;transform:translateX(-50%) translateY(8px);opacity:0;background:#263647;color:white;padding:9px 14px;font-size:10px;transition:.2s}.toast.show{opacity:1;transform:translateX(-50%)}
@media(max-width:760px){.layout{grid-template-columns:1fr}.form-grid{grid-template-columns:1fr}.field.full{grid-column:auto}.total-area{grid-template-columns:1fr}.total{border-right:0;border-bottom:1px solid var(--line)}.person{grid-template-columns:1fr 1fr}.hero h1{font-size:24px}.header-right{display:none}}
</style>
</head>
<body>
<div class="site">
<div class="topline"></div>
<header class="header">
  <div class="emblem">招</div>
  <div class="brand"><b>普通高校招生考试考生服务平台</b><span>GENERAL COLLEGE ADMISSION EXAMINATION SERVICE</span></div>
  
</header>
<section class="hero"><h1>普通高考成绩查询</h1><p>考生本人可凭姓名、考生号及身份信息查询考试成绩</p></section>

<main class="main">
  <div class="notice">成绩信息仅供考生本人查询。请妥善保管考生号及身份信息，查询完成后及时退出。</div>
  <section class="query" id="queryView">
    <div class="layout">
      <div class="card">
        <div class="card-head">考生成绩查询 <span>SCORE QUERY</span></div>
        <div class="query-body">
          <div class="form-grid">
            <div class="field"><label>考生姓名</label><input id="nameInput" value="傅时年" autocomplete="off"></div>
            <div class="field"><label>考生号</label><input id="examInput" value="260104071218" autocomplete="off"></div>
            <div class="field"><label>身份证号后六位</label><input id="idInput" value="071218" maxlength="6" autocomplete="off"></div>
            <div class="field"><label>考试类别</label><input value="普通高考 · 理工类" readonly></div>
            <div class="field full"><label>图形验证码</label><div class="verify"><input id="captchaInput" placeholder="请输入右侧验证码"><div class="captcha" id="captcha">7K2M</div><button class="reload" id="reloadCaptcha">↻</button></div></div>
          </div>
          <div class="actions"><button class="primary" id="queryBtn">查询成绩</button><button class="secondary" id="resetBtn">重置</button></div>
        </div>
      </div>
      <aside class="card tip-card">
        <h3>查询说明</h3>
        <ol>
          <li>考生姓名须与报名信息一致。</li>
          <li>考生号为12位数字。</li>
          <li>验证码不区分大小写。</li>
          <li>成绩报告可保存或打印。</li>
        </ol>
        <div class="service">服务状态：<b style="color:#24825a">正常</b><br>数据状态：已更新<br>咨询服务：工作日 08:30—17:30</div>
      </aside>
    </div>
  </section>

  <section class="result" id="resultView">
    <div class="card">
      <div class="result-banner"><div><b>普通高考成绩报告</b><span>成绩数据校验通过</span></div><div class="verified">✓ 已验证</div></div>
      <div class="person">
        <div><span>考生姓名</span><b>傅时年</b></div>
        <div><span>考生号</span><b>260104071218</b></div>
        <div><span>考试类别</span><b>理工类</b></div>
        <div><span>报名地区</span><b>省城市 · 青岩县</b></div>
      </div>
      <div class="total-area">
        <div class="total"><span>高考总成绩</span><strong id="totalScore">712</strong><em>七百一十二分</em></div>
        <div class="subjects">
          <div class="subject"><b>语文</b><div class="bar"><i style="width:84%"></i></div><strong data-score="126">126</strong></div>
          <div class="subject"><b>数学</b><div class="bar"><i style="width:99%"></i></div><strong data-score="148">148</strong></div>
          <div class="subject"><b>英语</b><div class="bar"><i style="width:87%"></i></div><strong data-score="131">131</strong></div>
          <div class="subject"><b>理科综合</b><div class="bar"><i style="width:96%"></i></div><strong data-score="307">307</strong></div>
        </div>
      </div>
      
      <div class="result-actions"><button class="primary" id="printBtn">打印成绩报告</button><button class="secondary" id="saveBtn">保存查询结果</button><button class="secondary" id="backBtn">返回查询</button></div>
    </div>
  </section>
</main>

</div>
<div class="toast" id="toast"></div>
<script>
(() => {
const $=s=>document.querySelector(s),$$=s=>[...document.querySelectorAll(s)];
let captcha="7K2M";
function toast(msg){const t=$("#toast");t.textContent=msg;t.classList.add("show");setTimeout(()=>t.classList.remove("show"),1400)}
function newCaptcha(){const chars="ABCDEFGHJKLMNPQRSTUVWXYZ23456789";captcha="";for(let i=0;i<4;i++)captcha+=chars[Math.floor(Math.random()*chars.length)];$("#captcha").textContent=captcha;$("#captchaInput").value=""}
$("#reloadCaptcha").onclick=newCaptcha;
$("#resetBtn").onclick=()=>{$("#nameInput").value="";$("#examInput").value="";$("#idInput").value="";newCaptcha()};
$("#queryBtn").onclick=()=>{
  const name=$("#nameInput").value.trim(),exam=$("#examInput").value.trim(),id=$("#idInput").value.trim(),cap=$("#captchaInput").value.trim().toUpperCase();
  if(!name||!exam||!id)return toast("请完整填写查询信息");
  if(cap!==captcha)return toast("验证码错误");
  if(name!=="傅时年"||exam!=="260104071218"||id!=="071218")return toast("未查询到匹配的考生成绩");
  $("#queryView").classList.add("hide");$("#resultView").classList.add("show");
  window.scrollTo({top:0,behavior:"smooth"});
};
$("#backBtn").onclick=()=>{$("#resultView").classList.remove("show");$("#queryView").classList.remove("hide");newCaptcha();window.scrollTo({top:0,behavior:"smooth"})};
$("#printBtn").onclick=()=>window.print();
$("#saveBtn").onclick=()=>{
 const text=`普通高考成绩报告
考生：傅时年
考生号：260104071218
总分：712
语文：126
数学：148
英语：131
理科综合：307
`;
 const blob=new Blob([text],{type:"text/plain;charset=utf-8"}),a=document.createElement("a");a.href=URL.createObjectURL(blob);a.download="傅时年_高考成绩报告.txt";a.click();URL.revokeObjectURL(a.href);toast("成绩报告已保存");
};
})();
</script>
</body>
</html>
